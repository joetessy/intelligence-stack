# Intelligence Stack — Secret Keys
# Copy this to .env and fill in your own values:
#   cp .env.example .env
#
# Generate keys with:
#   openssl rand -hex 32

# Open WebUI JWT signing key (used to sign auth tokens)
WEBUI_SECRET_KEY=your-secret-key-here

# SearXNG secret key (CSRF protection)
SEARXNG_SECRET=your-searxng-secret-here
